# ============================================================================
# MORIKAWA FERRE+ - MinIO Configuration Example
# Add these variables to your .env.local file for local image storage
# ============================================================================

# ============================================================================
# MINIO OBJECT STORAGE CONFIGURATION
# ============================================================================
# MinIO server connection details
# Default credentials for local MinIO: minioadmin:minioadmin

# MinIO server endpoint (for local development use: 127.0.0.1 or localhost)
MINIO_ENDPOINT="127.0.0.1"

# MinIO server port (default: 9000)
MINIO_PORT=9000

# Use SSL/TLS for MinIO connection (default: false for local)
MINIO_USE_SSL=false

# MinIO access key (default for local: minioadmin)
MINIO_ACCESS_KEY="minioadmin"

# MinIO secret key (default for local: minioadmin)
MINIO_SECRET_KEY="minioadmin"

# Bucket name for storing product images
MINIO_BUCKET="ferreteria"

# Public URL for accessing uploaded files (used in image URLs returned to clients)
# For local development: http://localhost:9000
# For production: https://minio.yourdomain.com or similar
MINIO_PUBLIC_URL="http://127.0.0.1:9000"

# ============================================================================
# RUNNING MINIO LOCALLY (Docker)
# ============================================================================
# To run MinIO locally with Docker, use this command:
#
# docker run -d \
#   -p 9000:9000 \
#   -p 9001:9001 \
#   -e MINIO_ROOT_USER=minioadmin \
#   -e MINIO_ROOT_PASSWORD=minioadmin \
#   -v minio_data:/minio_data \
#   --name minio \
#   minio/minio server /minio_data --console-address ":9001"
#
# This will:
# - Start MinIO server on port 9000 (API)
# - Start MinIO console on port 9001 (Web UI)
# - Create a docker-named volume for persistence
#
# Default credentials: minioadmin:minioadmin
# Console URL: http://localhost:9001
# ============================================================================
